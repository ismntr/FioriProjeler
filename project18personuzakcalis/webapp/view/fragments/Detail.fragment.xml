
<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
xmlns:appData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" >
    <Dialog id="_IDGenDialog1" title="{i18n>Detail}" resizable="true" draggable="true" horizontalScrolling="false"
        verticalScrolling="true" contentWidth="80%" contentHeight="70%">
         <content>
            <VBox id="_IDGenVBox1">
                <Panel id="_IDGenPanel1" class="sapUiResponsiveMargin" >
                    <l:VerticalLayout id="_IDGenVerticalLayout1" class="sapUiContentPadding" width="100%">
                        <l:content>
                            <Label id="_IDGenLabel1" text="{i18n>date}" textAlign="Left" labelFor="textDateId" design="Bold" />
                            <ObjectStatus id="_IDGenObjectStatus1" text="{path: 'mainModel>/Detail/Tarih', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd.MM.yyyy' } }" />
                            <Label id="_IDGenLabel2" text="{i18n>ename}" labelFor="textEnameId" design="Bold" />
                            <Text id="textEnameId" text="{mainModel>/Detail/Ename}" />
                            <VBox id="_IDGenVBox2">
                                <Label id="_IDGenLabel3" text="{i18n>plWorks}" design="Bold" labelFor="Pworks" />
                                <TextArea id="Pworks" value="{mainModel>/Detail/Works}" rows="5" width="50%" enabled="{= ${mainModel>/Detail/Basla} === 'F' ? false : true }" />
                            </VBox>
                            <VBox id="_IDGenVBox3">
                                <Label id="_IDGenLabel4" text="{i18n>ylworks}" labelFor="YworksTextArea" design="Bold" />
                                <TextArea id="YworksTextArea" value="{mainModel>/Detail/YWorks}" rows="5" width="50%" enabled="{= ${mainModel>/Detail/Basla} === 'B' ? true : false }" />
                            </VBox>
                        </l:content>
                    </l:VerticalLayout>
                </Panel>
            </VBox>
        </content>
        <buttons>
            <Button id="_IDGenButton1" text="{i18n>startButton}"  press="onPressButtonAction" icon="sap-icon://begin" appData:action="B" visible="{= ${mainModel>/Detail/Basla} === ''  ? true  : false }"/>
            <Button id="_IDGenButton2" text="{i18n>finishButton}" press="onPressButtonAction" icon="sap-icon://stop"  appData:action="F" visible="{= ${mainModel>/Detail/Basla} === 'B' ? true  : false }" />
            <Button id="_IDGenButton3" text="{i18n>saveButton}"   press="onPressButtonAction" icon="sap-icon://save"  appData:action=""  visible="{= ${mainModel>/Detail/Basla} === 'F' ? false : true }"/>
            <Button id="_IDGenButton4" text="{i18n>closeButton}"  press="onPressCloseDialog"  icon="sap-icon://decline" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>